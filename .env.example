# ─── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MongoDB ───────────────────────────────────────────────
# Use DB_HOST=mongodb when running inside Docker Compose.
# Leave DB_USER and DB_PSWD empty for unauthenticated local instances.
DB_HOST=localhost
DB_PORT=27017
DB_NAME=psdk_online
DB_USER=
DB_PSWD=

# ─── Auth ──────────────────────────────────────────────────
# Shared key required on every client request (x-api-key header / ?apiKey= WS param).
# Generate with: openssl rand -hex 32
API_KEY=change_me_with_a_strong_random_key

# Admin key for telemetry and Mystery Gift admin endpoints (x-admin-key header).
# Keep this strictly server-side — never expose it to game clients.
# Generate with: openssl rand -hex 32
ADMIN_KEY=change_me_with_a_different_strong_key

# ─── GTS ───────────────────────────────────────────────────
# Comma-separated species IDs that cannot be deposited or requested on the GTS.
# Example: 150,151 to block Mewtwo and Mew.
GTS_SPECIES_BLACKLIST=
GTS_EXPIRY_DAYS=30

# ─── PokeBank ──────────────────────────────────────────────
POKEBANK_MAX_BOXES=8
POKEBANK_BOX_SIZE=30

# ─── Docker Compose (full stack only) ──────────────────────
# Required only when using docker-compose.yml (not docker-compose.server-only.yml).
# The root user is created once on first container start and is used internally
# by MongoDB to bootstrap the application user defined by DB_USER/DB_PSWD.
# MONGO_INITDB_ROOT_USERNAME=adminuser
# MONGO_INITDB_ROOT_PASSWORD=adminpassword
