# ─── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# DB_NAME=psdk_online
# DB_HOST=mongodb          # 'mongodb' si géré par Docker, 'localhost' sinon
# DB_PORT=27017
# DB_USER=
# DB_PSWD=

# ─── Auth ─────────────────────────────────────────────────
# Clé partagée avec le client PSDK (header x-api-key)
# Générer avec : openssl rand -hex 32
API_KEY=change_me_with_a_strong_random_key

# Clé admin strictement serveur (x-admin-key header)
# Donne accès à : /telemetry/*, /api/v1/mystery-gift/admin/* etc...
# Générer avec : openssl rand -hex 32
ADMIN_KEY=change_me_with_a_different_strong_key

# ─── GTS ──────────────────────────────────────────────────
# IDs d'espèces séparés par virgule (ex: 000,001,151)
GTS_SPECIES_BLACKLIST=
GTS_EXPIRY_DAYS=30

# ─── PokeBank ─────────────────────────────────────────────
POKEBANK_MAX_BOXES=8
POKEBANK_BOX_SIZE=30
